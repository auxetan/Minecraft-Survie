# Copie ce fichier en .env et remplis les valeurs.
# Le fichier .env n'est JAMAIS commité (gitignore).

# GitHub Personal Access Token — nécessaire pour héberger le resource pack
# sur GitHub Releases (accessible depuis internet via playit.gg).
#
# Comment créer le token :
#   1. Va sur https://github.com/settings/tokens
#   2. "Generate new token (classic)"
#   3. Coche la permission "repo" (Full control of private repositories)
#   4. Copie le token ici
#
# Le repo doit être PUBLIC pour que les clients Minecraft puissent télécharger.
GITHUB_TOKEN=ghp_TON_TOKEN_ICI

# (Optionnel) Override manuel de l'URL du resource pack.
# Utilisé si GITHUB_TOKEN n'est pas défini.
# Exemple : PUBLIC_RP_URL=https://example.com/faithless.zip
# PUBLIC_RP_URL=
